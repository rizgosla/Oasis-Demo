---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact & Appointments — Oasis Dental Care, Huntington Beach"
  description="Request an appointment or reach out to Oasis Dental Care in Huntington Beach. Call (714) 893-2106 or fill out our online form."
  page="contact"
>

<section class="phero">
  <div class="wrap">
    <span class="tag">/ Contact</span>
    <h1>Let's get you in.</h1>
    <p>Request an appointment, ask a question, or tell us how we can help — someone warm will get back to you, usually the same day.</p>
  </div>
</section>

<section class="pad">
  <div class="wrap contact-grid">

    <div class="formcard reveal">
      <h2>Request an appointment</h2>
      <div class="note">New patients welcome. We accept most insurance plans and verify your benefits before your first visit.</div>

      <form name="appointment" method="POST" action="#">
        <div class="frow">
          <div class="field"><label>First name *</label><input type="text" name="first_name" placeholder="Jane" required /></div>
          <div class="field"><label>Last name *</label><input type="text" name="last_name" placeholder="Smith" required /></div>
        </div>
        <div class="frow">
          <div class="field"><label>Email *</label><input type="email" name="email" placeholder="jane@example.com" required /></div>
          <div class="field"><label>Phone</label><input type="tel" name="phone" placeholder="(714) 555-0000" /></div>
        </div>
        <div class="field">
          <label>Service interested in</label>
          <select name="service">
            <option value="">Select a service…</option>
            <option>General / Cleaning</option>
            <option>Cosmetic</option>
            <option>Dental Implants</option>
            <option>Invisalign®</option>
            <option>Crowns &amp; Bridges</option>
            <option>Emergency</option>
            <option>Teeth Whitening</option>
            <option>Root Canal</option>
            <option>Extractions</option>
            <option>Veneers</option>
            <option>Periodontal</option>
            <option>Pediatric</option>
            <option>Not sure — need a consult</option>
          </select>
        </div>
        <div class="field"><label>Preferred date / time</label><input type="text" name="preferred_time" placeholder="e.g. Mornings this week, or Fri afternoons" /></div>
        <div class="field"><label>Anything else we should know?</label><textarea name="message" placeholder="Dental anxiety, insurance details, urgent situation…"></textarea></div>
        <div style="margin-top:8px"><button type="submit" class="btn" style="width:100%;justify-content:center">Send request <svg class="ico" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></button></div>
      </form>
    </div>

    <div class="reveal" style="display:flex;flex-direction:column;gap:14px">
      <div class="infocard">
        <div class="bd">
          <h3>Visit us</h3>
          <div class="row"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg><div><b>Address</b>6552 Bolsa Ave, Suite J<br />Huntington Beach, CA 92647</div></div>
          <div class="row"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg><div><b>Phone</b><a href="tel:7148932106" style="color:var(--teal)">(714) 893-2106</a></div></div>
          <div class="row"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg><div><b>Email</b><a href="mailto:oasisdentalcarehb@yahoo.com" style="color:var(--teal)">oasisdentalcarehb@yahoo.com</a></div></div>
          <div style="margin-top:18px">
            <b style="font-size:15px">Hours</b>
            <div class="hours-list">
              <div class="hr"><span>Monday – Thursday</span><span>9:00 AM to 5:00 PM</span></div>
              <div class="hr"><span>Friday</span><span>9:00 AM to 4:00 PM</span></div>
              <div class="hr"><span>Saturday</span><span>By Appointment</span></div>
              <div class="hr c"><span>Sunday</span><span>Closed</span></div>
            </div>
          </div>
        </div>
        <div class="map"><iframe loading="lazy" title="Oasis Dental Care" src="https://maps.google.com/maps?q=6552%20Bolsa%20Ave%2C%20Suite%20J%20Huntington%20Beach%2C%20CA%2092647&t=m&z=15&output=embed&iwloc=near"></iframe></div>
      </div>
    </div>

  </div>
</section>

</Layout>
