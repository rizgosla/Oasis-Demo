---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Our Team — Oasis Dental Care, Huntington Beach"
  description="Meet Dr. Jason Fu and the Oasis Dental Care team in Huntington Beach — clinical excellence and genuine warmth."
  page="team"
>

<section class="phero">
  <div class="wrap">
    <span class="tag">/ Our Team</span>
    <h1>The people behind your smile.</h1>
    <p>Clinical excellence and genuine warmth — meet the team who make Oasis Dental Care the practice Huntington Beach trusts.</p>
  </div>
</section>

<section class="pad">
  <div class="wrap team-feature reveal">
    <div class="photo">
      <img src="https://oasisdentalcarehb.com/wp-content/uploads/2021/06/Dr-Jason-Fu-2021.jpg" alt="Dr. Jason Fu" />
    </div>
    <div>
      <span class="tag">Lead Dentist</span>
      <h2 style="font-size:clamp(30px,4vw,48px);margin-top:14px">Dr. Jason Fu</h2>
      <p style="font-size:17px;margin-top:16px;color:var(--ink-soft)">Dr. Fu brings over 25 years of clinical experience to Oasis Dental Care, combining advanced expertise with a calm, patient-focused approach. Whether you're in for preventive, restorative or cosmetic care, he takes the time to answer your questions and address every concern.</p>
      <p style="margin-top:14px;color:var(--ink-soft)">Together with Leandre and Edith, he has built a practice where clinical precision and genuine warmth go hand in hand.</p>
      <div style="display:flex;gap:30px;margin-top:24px;padding-top:20px;border-top:1px solid var(--line-l);width:fit-content">
        <div><div style="font-family:var(--disp);font-weight:600;font-size:22px;color:var(--teal)">25+</div><div style="font-size:10.5px;color:var(--ink-soft);margin-top:4px">Years experience</div></div>
        <div><div style="font-family:var(--disp);font-weight:600;font-size:22px;color:var(--teal)">10k+</div><div style="font-size:10.5px;color:var(--ink-soft);margin-top:4px">Smiles cared for</div></div>
        <div><div style="font-family:var(--disp);font-weight:600;font-size:22px;color:var(--teal)">5.0★</div><div style="font-size:10.5px;color:var(--ink-soft);margin-top:4px">Patient rated</div></div>
      </div>
      <div style="margin-top:24px"><a class="btn" href="/contact">Book with Dr. Fu</a></div>
    </div>
  </div>
</section>

<section style="padding:0 0 84px">
  <div class="wrap">
    <div class="shead reveal">
      <div><span class="tag">The full team</span><h2>Every visit, a familiar face.</h2></div>
    </div>
    <div class="team reveal">
      <div class="member">
        <div class="photo">
          <div class="ph">
            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Photo after photoshoot</span>
          </div>
        </div>
        <div class="info">
          <div class="nm">Leandre</div>
          <div class="rl">Lead Back Office Manager</div>
          <p>Keeps every clinical appointment running smoothly — from sterilisation protocols to chairside support. Patients consistently note how calm and reassuring she is.</p>
        </div>
      </div>
      <div class="member">
        <div class="photo">
          <div class="ph">
            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>Photo after photoshoot</span>
          </div>
        </div>
        <div class="info">
          <div class="nm">Edith</div>
          <div class="rl">Office Manager</div>
          <p>The welcoming face of Oasis — handling scheduling, insurance verification, and making sure every patient feels at home from the moment they walk in.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta">
  <div class="wrap">
    <div class="ctacard reveal">
      <div class="grid-ov"></div>
      <div class="c"><span class="tag">We'd love to meet you</span><h2>Come say hello.</h2><p>New patients are always welcome. Book online or call — we'll take it from there.</p></div>
      <div class="acts"><a class="btn" href="tel:7148932106">Call (714) 893-2106</a><a class="btn btn-o" href="/contact">Request appointment</a></div>
    </div>
  </div>
</section>

</Layout>
