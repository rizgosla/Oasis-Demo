---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Oasis Dental Care — Precision dentistry in Huntington Beach"
  description="Precision, technology-forward dentistry in Huntington Beach. Same-day crowns, 3D imaging, implants & Invisalign with Dr. Jason Fu. Call (714) 893-2106."
>

<!-- hero -->
<section class="hero reveal in">
  <div class="heromain">
    <div class="inner">
      <div class="copy">
        <span class="tag" style="font-size:15px">Precision dentistry · Huntington Beach</span>
        <h1>Oasis Dental Care.<br /><span>Achieve a smile you'll love!</span></h1>
        <p>Whether you're visiting us for the first time or coming back to see our team, you can expect personalized attention and a warm, relaxed atmosphere.</p>
        <div class="acts">
          <a class="btn" href="/contact">Request appointment <svg class="ico" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          <a class="btn btn-ghost" href="tel:7148932106">Call (714) 893-2106</a>
        </div>
      </div>
      <div class="media">
        <div class="ph">
          <div class="ic"><svg viewBox="0 0 24 24"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="8.5" cy="10" r="1.6"/><path d="m21 16-4.5-4.5L7 21"/></svg></div>
          <div class="t">Team photo</div>
          <div class="s">Placeholder — drop in your real team photos after the shoot.</div>
        </div>
        <div class="badge" style="font-size:12px"><span class="pulse" style="width:6px;height:6px;border-radius:50%;background:var(--teal-300)"></span>Our Team</div>
      </div>
    </div>
  </div>
</section>

<!-- marquee -->
<div class="strip">
  <div class="track">
    <span><b>+</b> General Dentistry <b>+</b> Implants <b>+</b> Invisalign® <b>+</b> Cosmetic <b>+</b> Same-Day Crowns <b>+</b> Emergency Care <b>+</b> Teeth Whitening <b>+</b> Root Canal <b>+</b> Pediatric <b>+</b> Veneers</span>
    <span><b>+</b> General Dentistry <b>+</b> Implants <b>+</b> Invisalign® <b>+</b> Cosmetic <b>+</b> Same-Day Crowns <b>+</b> Emergency Care <b>+</b> Teeth Whitening <b>+</b> Root Canal <b>+</b> Pediatric <b>+</b> Veneers</span>
  </div>
</div>

<!-- practice info bar -->
<div class="stat-band reveal">
  <div class="wrap">
    <div class="stat-row">
      <div class="stat"><div class="n">25+</div><div class="l">Years of experience</div></div>
      <div class="stat"><div class="n">10k+</div><div class="l">Smiles cared for</div></div>
      <div class="stat"><div class="n">4.8★</div><div class="l">Patient rated</div></div>
      <div class="stat"><div class="n">Same-day</div><div class="l">Emergency care</div></div>
    </div>
  </div>
</div>

<!-- services card deck -->
<section class="pad" id="services">
  <div class="wrap">
    <div class="services-layout reveal">

      <!-- left: copy + controls + CTA -->
      <div class="services-copy">
        <h2>Every treatment, one system.</h2>
        <p>A full-service practice — from preventive visits to advanced restorative and cosmetic work, all under one roof in Huntington Beach.</p>
        <div class="deck-bar">
          <button class="deck-arrow" id="deckPrev" aria-label="Previous service">
            <svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <div class="deck-dots" id="deckDots"></div>
          <button class="deck-arrow" id="deckNext" aria-label="Next service">
            <svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
        <a class="btn btn-out" href="/services">View all services <svg class="ico" viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
      </div>

      <!-- right: card stack -->
      <div class="deck-stage" id="serviceDeck">

        <div class="svc-card">
          <div class="svc-top">
            <div class="svc-ic"><svg viewBox="0 0 24 24"><path d="M9 2C6.5 2 5 4.5 5 7c0 2.5.8 4.8 1.6 7.5L8 22h8l1.4-7.5C18.2 11.8 19 9.5 19 7c0-2.5-1.5-5-4-5-1 0-1.8.5-3 .5-1.2 0-2-.5-3-.5z"/></svg></div>
            <span class="svc-num">01 / 06</span>
          </div>
          <div class="svc-body">
            <h3>General Dentistry</h3>
            <p>Cleanings, exams and checkups that keep your smile strong — for patients of every age, from first visits to lifelong care.</p>
          </div>
          <a class="svc-cta" href="/services/general-dentistry">Learn more <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>

        <div class="svc-card">
          <div class="svc-top">
            <div class="svc-ic"><svg viewBox="0 0 24 24"><path d="M10 3C8 3 7 5 7 7c0 2 .6 3.8 1.2 6L9.5 19h5L16 13c.6-2.2 1.2-4 1.2-6 0-2-1-4-3.2-4-1 0-1.5.4-2 .4S11 3 10 3z"/><path d="M19 2l.5 1.5 1.5.5-1.5.5L19 6l-.5-1.5L17 4l1.5-.5z"/></svg></div>
            <span class="svc-num">02 / 06</span>
          </div>
          <div class="svc-body">
            <h3>Cosmetic Dentistry</h3>
            <p>Whitening, veneers and bonding tailored to your goals — creating results that look and feel naturally like you.</p>
          </div>
          <a class="svc-cta" href="/services/cosmetic-dentistry">Learn more <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>

        <div class="svc-card">
          <div class="svc-top">
            <div class="svc-ic"><svg viewBox="0 0 24 24"><path d="M9.5 2C7 2 5.5 4 5.5 6.5c0 2.3.7 4.3 1.4 7L8 20h8l1.1-6.5c.7-2.7 1.4-4.7 1.4-7C18.5 4 17 2 14.5 2z"/><path d="M12 10v4M10 14h4"/></svg></div>
            <span class="svc-num">03 / 06</span>
          </div>
          <div class="svc-body">
            <h3>Emergency Dentistry</h3>
            <p>Same-day relief for toothaches, broken teeth and dental infections. We set aside time daily for urgent needs so you're never left waiting.</p>
          </div>
          <a class="svc-cta" href="/services/emergency-dentistry">Learn more <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>

        <div class="svc-card">
          <div class="svc-top">
            <div class="svc-ic"><svg viewBox="0 0 24 24"><path d="M3 20h18M5 20V10l3.5 4L12 3l3.5 11L19 10v10"/></svg></div>
            <span class="svc-num">04 / 06</span>
          </div>
          <div class="svc-body">
            <h3>Crowns &amp; Bridges</h3>
            <p>Custom restorations that repair damaged teeth and replace missing ones — built to blend seamlessly, many completed in a single visit.</p>
          </div>
          <a class="svc-cta" href="/services/crowns-bridges">Learn more <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>

        <div class="svc-card">
          <div class="svc-top">
            <div class="svc-ic"><svg viewBox="0 0 24 24"><path d="M12 2v7"/><rect x="9" y="9" width="6" height="3" rx="1"/><path d="M10.5 12l-1 8h5l-1-8"/><path d="M9.5 20h5"/></svg></div>
            <span class="svc-num">05 / 06</span>
          </div>
          <div class="svc-body">
            <h3>Dental Implants</h3>
            <p>A permanent, secure solution for missing teeth that looks and feels just like the real thing — backed by cutting-edge technology and expert placement.</p>
          </div>
          <a class="svc-cta" href="/services/dental-implants">Learn more <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>

        <div class="svc-card">
          <div class="svc-top">
            <div class="svc-ic"><svg viewBox="0 0 24 24"><path d="M3 10c0-2.8 4-5 9-5s9 2.2 9 5v2a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><path d="M7 14v2.5M12 14.5V18M17 14v2.5"/></svg></div>
            <span class="svc-num">06 / 06</span>
          </div>
          <div class="svc-body">
            <h3>Invisalign Treatment</h3>
            <p>Clear, removable aligners that gradually move your teeth into place — nearly invisible and built around your lifestyle.</p>
          </div>
          <a class="svc-cta" href="/services/invisalign">Learn more <svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- tech / difference -->
<section class="pad tech" id="difference">
  <div class="bg-glow"></div>
  <div class="wrap">
    <div class="shead reveal">
      <div><span class="tag">The Oasis difference</span><h2>Built around precision &amp; comfort.</h2></div>
      <p>It's not just the technology — it's how we listen, explain, and treat every patient like a neighbor.</p>
    </div>
    <div class="tgrid reveal">
      <div class="tcard"><div class="num">01 — Scheduling</div><h3>Respecting Your Time</h3><p>Your time matters. We operate on a schedule with the patient in mind—no waiting around or delays.</p></div>
      <div class="tcard"><div class="num">02 — Safety</div><h3>Putting Safety First</h3><p>We follow sterilization protocols recommended by the ADA, CDC, and OSHA to ensure a safe, clean environment.</p></div>
      <div class="tcard"><div class="num">03 — Orthodontics</div><h3>Straighten Your Way</h3><p>We give patients the option to choose from traditional braces or nearly invisible Invisalign.</p></div>
      <div class="tcard"><div class="num">04 — Technology</div><h3>Leading-Edge Care</h3><p>From 3D imaging to same-day crowns, we choose technology that makes your visit safer and more precise.</p></div>
      <div class="tcard"><div class="num">05 — Community</div><h3>Rooted in Community</h3><p>From Surf City families to local business owners and weekend beachgoers, we're proud to serve the community we call home.</p></div>
      <div class="tcard"><div class="num">06 — Services</div><h3>Full-Service Dentistry</h3><p>Whether you need a routine checkup, a smile makeover, or a helping hand in an emergency, you won't need to travel far.</p></div>
    </div>
  </div>
</section>

<!-- doctor -->
<section class="pad doc" id="doctor">
  <div class="wrap">
    <div class="pic reveal">
      <img src="https://oasisdentalcarehb.com/wp-content/uploads/2021/06/Dr-Jason-Fu-2021.jpg" alt="Dr. Jason Fu" />
      <div class="ovl"><span class="nm">Dr. Jason Fu</span><span class="rl" style="font-size:15px">Lead Dentist</span></div>
    </div>
    <div class="reveal">
      <h2>Decades of clinical excellence and patient care</h2>
      <p>Dr. Jason Fu brings over 25 years of clinical experience to Oasis Dental Care, combining advanced dental expertise with a calm, patient-focused approach. He is committed to delivering thoughtful, individualized care—whether you're visiting for preventive treatment, restorative work, or cosmetic enhancements.</p>
      <p>Together, Dr. Fu and the Oasis Dental team are focused on creating a welcoming environment where clinical excellence and patient comfort go hand in hand.</p>
      <div class="meta">
        <div><div class="n">25+</div><div class="l">Years exp.</div></div>
        <div><div class="n">10k+</div><div class="l">Smiles cared for</div></div>
        <div><div class="n">4.8★</div><div class="l">Patient rated</div></div>
      </div>
    </div>
  </div>
</section>

<!-- reviews -->
<section class="pad rev" id="reviews">
  <div class="wrap">
    <div class="shead reveal">
      <div><span class="tag">Patient reviews</span><h2>4.8 average. Real people.</h2></div>
      <p>From first-timers to patients of a decade — here's the Huntington Beach community on Oasis.</p>
    </div>
    <div class="rgrid reveal">
      <div class="rc"><div class="top"><span class="st">★★★★★</span><span class="src">Google</span></div><q>Everyone is friendly and professional. I always learn something new and get good advice.</q><div class="who">Robert W. · Since 2015</div></div>
      <div class="rc"><div class="top"><span class="st">★★★★★</span><span class="src">Yelp</span></div><q>They eased my nerves and made it far less scary. Clean, accurate and affordable work.</q><div class="who">Saga E. · Los Angeles</div></div>
      <div class="rc"><div class="top"><span class="st">★★★★★</span><span class="src">Google</span></div><q>This is the future of dentistry right here. Recommend ten times over.</q><div class="who">Michelle G. · Los Angeles</div></div>
    </div>
  </div>
</section>

<!-- location -->
<section class="pad loc" id="location">
  <div class="wrap reveal">
    <div class="info">
      <span class="tag">Visit us</span>
      <h2>6552 Bolsa Ave, Suite J</h2>
      <div class="addr">Huntington Beach, CA 92647<br /><a href="tel:7148932106" style="color:var(--teal);font-weight:600">(714) 893-2106</a> · oasisdentalcarehb@yahoo.com</div>
      <div class="hours">
        <div class="hr"><span>Monday – Thursday</span><span>09:00 AM to 5:00 PM</span></div>
        <div class="hr"><span>Friday</span><span>09:00 AM to 4:00 PM</span></div>
        <div class="hr"><span>Saturday</span><span>By Appointment</span></div>
        <div class="hr c"><span>Sunday</span><span>Closed</span></div>
      </div>
      <div style="margin-top:24px;display:flex;gap:12px;flex-wrap:wrap">
        <a class="btn" href="https://share.google/4JPggQxNi53ulxJRx" target="_blank" rel="noopener">Directions</a>
        <a class="btn btn-out" href="/contact">Patient forms</a>
      </div>
    </div>
    <div class="map">
      <iframe loading="lazy" title="Map" src="https://maps.google.com/maps?cid=8858444920419398576&t=m&z=17&output=embed"></iframe>
    </div>
  </div>
</section>

<!-- book -->
<section class="book" id="book">
  <div class="wrap">
    <div class="bookcard reveal">
      <div class="bg-glow-teal"></div>
      <div class="c">
        <span class="tag" style="font-size:15px">New patients welcome</span>
        <h2>Ready when you are.</h2>
        <p>Tell us a good time and someone warm will get back to you — usually the same day.</p>
      </div>
      <div class="acts">
        <a class="btn" href="tel:7148932106">Call (714) 893-2106</a>
        <a class="btn btn-o" href="/contact">Request online</a>
      </div>
    </div>
  </div>
</section>

<script>
(function () {
  const stage = document.getElementById('serviceDeck');
  if (!stage) return;
  const cards = [...stage.querySelectorAll('.svc-card')];
  const dotsEl = document.getElementById('deckDots');
  const N = cards.length;
  let cur = 0, busy = false;

  for (let i = 0; i < N; i++) {
    const d = document.createElement('button');
    d.className = 'deck-dot';
    d.setAttribute('aria-label', 'Service ' + (i + 1));
    d.addEventListener('click', () => go(i));
    dotsEl.appendChild(d);
  }

  function setDots() {
    [...dotsEl.children].forEach((d, i) => d.classList.toggle('on', i === cur));
  }

  function go(next) {
    if (busy || next === cur) return;
    busy = true;
    const exitIdx = cur;
    const top = cards[exitIdx];

    // Swipe top card out to the right — keep it visually on top the whole time
    top.style.transition = 'transform .42s cubic-bezier(.4,0,.6,1), opacity .38s ease-in';
    top.style.transform = 'translateX(115%)';
    top.style.opacity = '0';
    top.style.zIndex = '20';
    top.style.pointerEvents = 'none';

    // Immediately advance cur and shift the cards below forward —
    // they smoothly animate to their new positions while the top card swipes away
    cur = ((next % N) + N) % N;
    cards.forEach((c, i) => {
      if (i === exitIdx) return;
      c.dataset.pos = String(Math.min((i - cur + N) % N, 3));
    });
    setDots();

    setTimeout(() => {
      // Snap the exited card to back-of-pile instantly (no transition)
      top.style.transition = 'none';
      top.style.transform = 'translateY(26px) scale(0.91)';
      top.style.opacity = '0';
      top.style.zIndex = '';
      top.style.pointerEvents = '';
      top.dataset.pos = String(Math.min((exitIdx - cur + N) % N, 3));
      // Re-enable CSS so future transitions work normally
      requestAnimationFrame(() => requestAnimationFrame(() => {
        top.style.cssText = '';
        busy = false;
      }));
    }, 450);
  }

  document.getElementById('deckNext').addEventListener('click', () => go((cur + 1) % N));
  document.getElementById('deckPrev').addEventListener('click', () => go((cur - 1 + N) % N));

  let timer = setInterval(() => go((cur + 1) % N), 10000);
  stage.addEventListener('mouseenter', () => clearInterval(timer));
  stage.addEventListener('mouseleave', () => { timer = setInterval(() => go((cur + 1) % N), 10000); });

  // init
  cards.forEach((c, i) => { c.dataset.pos = String(Math.min(i, 3)); });
  setDots();
})();
</script>

</Layout>
